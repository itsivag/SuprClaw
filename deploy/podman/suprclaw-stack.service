[Unit]
Description=SuprClaw Podman Stack
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
EnvironmentFile=-/etc/default/suprclaw-stack
ExecStart=/opt/suprclaw/podman/up.sh
ExecStop=/opt/suprclaw/podman/down.sh
TimeoutStartSec=300
TimeoutStopSec=120

[Install]
WantedBy=multi-user.target
